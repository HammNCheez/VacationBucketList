    "backend:format:check": ".\\.venv\\Scripts\\python.exe -m black --check backend",
    "backend:test": "cd backend && ..\\.venv\\Scripts\\python.exe -m pytest -q tests",
    "backend:migrate": "cd backend && ..\\.venv\\Scripts\\python.exe -m database.migrate",
