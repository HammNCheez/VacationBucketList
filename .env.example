# .env.example — copy to .env and fill in real values before running docker compose.
# Never commit .env to version control.

# ----- Image configuration -----
# Your lowercase GitHub username or organisation name (must match the GHCR image owner).
GHCR_OWNER=your-github-username

# Tag to deploy.  Use a semver tag (e.g. 1.2.3) for stable releases,
# a short SHA (e.g. sha-1a2b3c4) for exact pinning, or "latest" for rolling updates.
IMAGE_TAG=latest

# ----- Frontend -----
# URL that the frontend nginx container uses to reach the backend API.
# Default is same host on port 8000.
# If backend/frontend run in the same docker compose network, set to:
#   http://backend:8000
BACKEND_URL=http://localhost:8000

# ----- Backend — shared -----
ORS_API_KEY=your_openrouteservice_api_key

# ----- Backend — MySQL (docker-compose.mysql.yml only) -----
DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=vacation_bucket_list
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ----- Backend — SQLite (docker-compose.sqlite.yml only) -----
# Host directory that will be bind-mounted to /config inside the container.
DATA_DIR=/config/vacation-bucket-list
